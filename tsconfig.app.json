{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Path alias: `@/` maps to `src/` (kept in sync with vite.config.ts).
       No baseUrl needed — TS resolves these patterns relative to this file. */
    "paths": {
      "@/*": ["./src/*"]
    },

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    /* Extra strictness (DECISIONS.md F2): catch unchecked array/object access.
       exactOptionalPropertyTypes deliberately omitted — too noisy while prototyping. */
    "noUncheckedIndexedAccess": true
  },
  "include": ["src"]
}
