{
  "$description": "KIO Studio design tokens — W3C DTCG format. Git-canonical source of truth (DECISIONS.md D4). SEEDED placeholders: replace with real CoreMedia brand values in the brand-token phase. Built to src/styles/tokens.css by Style Dictionary.",
  "color": {
    "$type": "color",
    "brand": {
      "primary": {
        "$value": "oklch(0.55 0.18 255)",
        "$description": "Primary action color — placeholder blue so the token pipeline is visibly distinct from shadcn defaults."
      },
      "primary-hover": {
        "$value": "oklch(0.5 0.18 255)",
        "$description": "Primary, hovered/active."
      },
      "primary-foreground": {
        "$value": "oklch(0.985 0 0)",
        "$description": "Text/icon color on top of primary."
      }
    },
    "neutral": {
      "50": { "$value": "oklch(0.985 0 0)" },
      "100": { "$value": "oklch(0.97 0 0)" },
      "200": { "$value": "oklch(0.922 0 0)" },
      "300": { "$value": "oklch(0.87 0 0)" },
      "400": { "$value": "oklch(0.708 0 0)" },
      "500": { "$value": "oklch(0.556 0 0)" },
      "600": { "$value": "oklch(0.439 0 0)" },
      "700": { "$value": "oklch(0.371 0 0)" },
      "800": { "$value": "oklch(0.269 0 0)" },
      "900": { "$value": "oklch(0.205 0 0)" }
    },
    "semantic": {
      "background": { "$value": "oklch(1 0 0)" },
      "foreground": { "$value": "oklch(0.145 0 0)" },
      "border": {
        "$value": "{color.neutral.200}",
        "$description": "Alias → neutral.200. Demonstrates DTCG references resolving through Style Dictionary."
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "$description": "4px base scale.",
    "1": { "$value": "0.25rem" },
    "2": { "$value": "0.5rem" },
    "3": { "$value": "0.75rem" },
    "4": { "$value": "1rem" },
    "5": { "$value": "1.25rem" },
    "6": { "$value": "1.5rem" },
    "8": { "$value": "2rem" }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "0.375rem" },
    "md": { "$value": "0.5rem" },
    "lg": { "$value": "0.625rem" }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "sans": { "$value": "'Geist Variable', system-ui, sans-serif" },
      "mono": { "$value": "ui-monospace, 'Geist Mono', monospace" }
    },
    "size": {
      "$type": "dimension",
      "xs": { "$value": "0.75rem" },
      "sm": { "$value": "0.875rem" },
      "base": { "$value": "1rem" },
      "lg": { "$value": "1.125rem" },
      "xl": { "$value": "1.25rem" },
      "2xl": { "$value": "1.5rem" }
    },
    "weight": {
      "$type": "fontWeight",
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold": { "$value": 700 }
    },
    "line-height": {
      "$type": "number",
      "tight": { "$value": 1.25 },
      "normal": { "$value": 1.5 },
      "relaxed": { "$value": 1.75 }
    }
  }
}
